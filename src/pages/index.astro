---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { BRAND_NAME } from '../lib/brand';
import { getCollection } from 'astro:content';

const servicii = await getCollection('servicii');
const serviciiOrdonate = servicii.sort((a, b) => a.data.ordine - b.data.ordine);
---

<PageLayout title={BRAND_NAME} description="Site-uri și soluții IT construite pe măsură.">
  <section class="p-8 max-w-4xl mx-auto py-16 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">
      Soluții digitale și servicii IT construite pe măsură
    </h1>
    <p class="text-lg opacity-70 mt-4 max-w-2xl mx-auto">
      Dezvoltare web rapidă, mentenanță tehnică și infrastructură IT stabilă pentru afacerea ta.
    </p>
    <div class="mt-8 flex gap-4 justify-center">
      <a href="/contact" class="bg-[var(--color-ink)] text-[var(--color-paper)] px-6 py-3 rounded-lg font-medium hover:opacity-90 transition">
        Cere o ofertă
      </a>
      <a href="/servicii" class="border px-6 py-3 rounded-lg font-medium hover:opacity-70 transition">
        Vezi serviciile
      </a>
    </div>
  </section>

  <section class="max-w-2xl mx-auto p-8 border-t border-black/10">
    <h2 class="text-2xl font-bold mb-6">Servicii principale</h2>
    <div class="flex flex-col gap-4">
      {serviciiOrdonate.map((serviciu) => (
        <ServiceCard 
          titlu={serviciu.data.titlu}
          rezumat={serviciu.data.rezumat}
          slug={serviciu.data.slug}
        />
      ))}
    </div>
  </section>
</PageLayout>