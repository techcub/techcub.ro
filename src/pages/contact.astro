---
import PageLayout from '../layouts/PageLayout.astro';
import { CONTACT_EMAIL, CONTACT_PHONE, SOCIAL_LINKS } from '../lib/brand';
---

<PageLayout title="Contact" description="Ai un proiect în minte sau o problemă tehnică? Scrie-mi sau sună-mă.">
  <section class="p-8 max-w-4xl mx-auto py-12">
    <div class="text-center max-w-xl mx-auto mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20 text-xs font-semibold mb-4">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        Disponibil pentru proiecte noi
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight">Hai să vorbim</h1>
      <p class="mt-3 opacity-80 text-base">
        Alege metoda cea mai comodă pentru tine. Răspund prompt la orice mesaj sau apel.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="p-6 bg-[var(--color-card)] rounded-2xl border border-[var(--color-border)] shadow-sm hover:shadow-md transition duration-200 flex flex-col justify-between group">
        <div>
          <div class="w-12 h-12 rounded-xl bg-blue-500/10 text-blue-600 dark:text-blue-400 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 002-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <span class="text-xs font-bold uppercase tracking-wider opacity-50">Email</span>
          <h3 class="text-xl font-bold mt-0.5">{CONTACT_EMAIL}</h3>
          <p class="text-xs opacity-60 mt-1">Ideal pentru cereri de ofertă și detalii despre proiecte.</p>
        </div>

        <div class="mt-6 flex items-center gap-3">
          <a 
            href={`mailto:${CONTACT_EMAIL}`}
            class="flex-1 text-center py-2.5 px-4 bg-[var(--color-ink)] text-[var(--color-paper)] text-sm font-medium rounded-lg hover:opacity-90 transition"
          >
            Trimite Mail
          </a>
          <button 
            id="copy-email-btn"
            data-email={CONTACT_EMAIL}
            class="py-2.5 px-4 bg-[var(--color-paper)] border border-[var(--color-border)] hover:bg-black/5 dark:hover:bg-white/10 text-sm font-medium rounded-lg transition relative"
            title="Copiază adresa de email"
          >
            <span id="copy-text">Copiază</span>
          </button>
        </div>
      </div>

      <div class="p-6 bg-[var(--color-card)] rounded-2xl border border-[var(--color-border)] shadow-sm hover:shadow-md transition duration-200 flex flex-col justify-between group">
        <div>
          <div class="w-12 h-12 rounded-xl bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 flex items-center justify-center mb-4 group-hover:scale-105 transition-transform">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <span class="text-xs font-bold uppercase tracking-wider opacity-50">Telefon / WhatsApp</span>
          <h3 class="text-xl font-bold mt-0.5">{CONTACT_PHONE}</h3>
          <p class="text-xs opacity-60 mt-1">Disponibil oricând pe mesaj sau pentru un apel rapid.</p>
        </div>

        <div class="mt-6 flex items-center gap-3">
          <a 
            href={`tel:${CONTACT_PHONE.replace(/\s+/g, '')}`}
            class="flex-1 text-center py-2.5 px-4 bg-[var(--color-ink)] text-[var(--color-paper)] text-sm font-medium rounded-lg hover:opacity-90 transition"
          >
            Sună-mă
          </a>
          <a 
            href={SOCIAL_LINKS.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 text-center py-2.5 px-4 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg transition flex items-center justify-center gap-1.5"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  function setupCopyButton() {
    const copyBtn = document.getElementById('copy-email-btn');
    const copyText = document.getElementById('copy-text');

    if (copyBtn && copyText) {
      copyBtn.addEventListener('click', () => {
        const email = copyBtn.getAttribute('data-email') || '';
        navigator.clipboard.writeText(email);
        
        const originalText = copyText.innerText;
        copyText.innerText = 'Copiat! ✓';

        setTimeout(() => {
          copyText.innerText = originalText;
        }, 2000);
      });
    }
  }

  setupCopyButton();
  document.addEventListener('astro:page-load', setupCopyButton);
</script>