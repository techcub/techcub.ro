---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';

const servicii = await getCollection('servicii');
const serviciiOrdonate = servicii.sort((a, b) => a.data.ordine - b.data.ordine);
---

<PageLayout title="Servicii" description="Toate serviciile noastre, într-un singur loc.">
  <section class="p-8 max-w-2xl mx-auto py-8">
    <h1 class="text-4xl font-bold mb-8">Servicii</h1>

    <div class="flex flex-col gap-4">
      {serviciiOrdonate.map((serviciu) => (
        <ServiceCard 
          titlu={serviciu.data.titlu}
          rezumat={serviciu.data.rezumat}
          slug={serviciu.data.slug}
        />
      ))}
    </div>
  </section>
</PageLayout>