---
import { BRAND_NAME, LEGAL_NAME, LEGAL_CUI, LEGAL_REG_COM } from '../../lib/brand';
---

<footer class="p-6 text-sm text-center opacity-70">
  <p>&copy; {new Date().getFullYear()} {BRAND_NAME}</p>
  <p class="mt-1">{LEGAL_NAME} · CUI: {LEGAL_CUI} · Reg. Com.: {LEGAL_REG_COM}</p>
  <p class="mt-2 flex gap-3 justify-center flex-wrap">
    <a href="/confidentialitate" class="underline hover:opacity-70">Confidențialitate</a>
    <a href="https://anpc.ro" target="_blank" rel="noopener" class="underline hover:opacity-70">ANPC</a>
    <a href="https://ec.europa.eu/consumers/odr" target="_blank" rel="noopener" class="underline hover:opacity-70">Soluționarea online a litigiilor</a>
  </p>
</footer>