---
import { BRAND_NAME, LEGAL_NAME, LEGAL_CUI, LEGAL_REG_COM, LEGAL_ADDRESS, SOCIAL_LINKS } from '../../lib/brand';
---

<footer class="relative z-10 p-6 text-sm text-center opacity-90 border-t border-black/10 mt-12 bg-transparent">
  <div class="flex justify-center items-center gap-6 mb-6">
    <!-- GitHub -->
    <a 
      href={SOCIAL_LINKS.github} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="relative z-20 cursor-pointer p-2.5 rounded-lg hover:bg-black/5 text-black/70 hover:text-black transition-all duration-200"
      aria-label="GitHub"
      title="GitHub"
    >
      <svg class="w-6 h-6 fill-current pointer-events-none" viewBox="0 0 24 24">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
      </svg>
    </a>

    <!-- LinkedIn -->
    <a 
      href={SOCIAL_LINKS.linkedin} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="relative z-20 cursor-pointer p-2.5 rounded-lg hover:bg-black/5 text-black/70 hover:text-black transition-all duration-200"
      aria-label="LinkedIn"
      title="LinkedIn"
    >
      <svg class="w-6 h-6 fill-current pointer-events-none" viewBox="0 0 24 24">
        <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.28 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.75M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
      </svg>
    </a>

    <!-- WhatsApp -->
    <a 
      href={SOCIAL_LINKS.whatsapp} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="relative z-20 cursor-pointer p-2.5 rounded-lg hover:bg-black/5 text-black/70 hover:text-black transition-all duration-200"
      aria-label="WhatsApp"
      title="WhatsApp"
    >
      <svg class="w-6 h-6 fill-current pointer-events-none" viewBox="0 0 24 24">
        <path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21 5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.816 9.816 0 0 0 12.04 2m.01 1.67c2.2 0 4.26.86 5.82 2.42a8.225 8.225 0 0 1 2.41 5.83c0 4.54-3.7 8.24-8.24 8.24-1.48 0-2.93-.4-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.32a8.188 8.188 0 0 1-1.26-4.38c.01-4.54 3.71-8.24 8.26-8.24m4.52 10.3c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.17.25-.64.81-.79.97-.15.17-.3.19-.55.07-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.15-.25-.02-.38.1-.5.11-.11.25-.29.37-.43.12-.14.17-.25.25-.41.08-.17.04-.31-.02-.43s-.56-1.34-.76-1.84c-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.84-.86 2.05 0 1.21.88 2.38 1 2.54.12.17 1.73 2.64 4.2 3.7.59.25 1.05.4 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.15-1.18-.07-.1-.23-.16-.48-.28z"/>
      </svg>
    </a>

    <!-- Facebook -->
    <a 
      href={SOCIAL_LINKS.facebook} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="relative z-20 cursor-pointer p-2.5 rounded-lg hover:bg-black/5 text-black/70 hover:text-black transition-all duration-200"
      aria-label="Facebook"
      title="Facebook"
    >
      <svg class="w-6 h-6 fill-current pointer-events-none" viewBox="0 0 24 24">
        <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H7.5v-3H10V9.5C10 7.01 11.49 5.65 13.75 5.65c1.08 0 2.21.19 2.21.19v2.43h-1.25c-1.23 0-1.61.77-1.61 1.56V12h2.74l-.44 3h-2.3v6.8c4.56-.93 8-4.96 8-9.8z"/>
      </svg>
    </a>

    <!-- Instagram -->
    <a 
      href={SOCIAL_LINKS.instagram} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="relative z-20 cursor-pointer p-2.5 rounded-lg hover:bg-black/5 text-black/70 hover:text-black transition-all duration-200"
      aria-label="Instagram"
      title="Instagram"
    >
      <svg class="w-6 h-6 fill-current pointer-events-none" viewBox="0 0 24 24">
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
      </svg>
    </a>
  </div>

  <p>&copy; {new Date().getFullYear()} {BRAND_NAME}</p>
  <p class="mt-1">{LEGAL_NAME} · CUI: {LEGAL_CUI} · Reg. Com.: {LEGAL_REG_COM}</p>
  <p class="mt-1">{LEGAL_ADDRESS}</p>
  <p class="mt-2 flex gap-3 justify-center flex-wrap">
    <a href="/confidentialitate" class="underline hover:opacity-70 relative z-20">Confidențialitate</a>
    <a href="https://anpc.ro" target="_blank" rel="noopener" class="underline hover:opacity-70 relative z-20">ANPC</a>
  </p>
</footer>