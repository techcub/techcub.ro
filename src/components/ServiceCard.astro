---
import Icon from './Icon.astro';

interface Props {
  titlu: string;
  rezumat: string;
  slug: string;
  icon: string;
}

const { titlu, rezumat, slug, icon } = Astro.props;
---

<a 
  href={`/servicii/${slug}`} 
  class="p-6 rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)] transition-all duration-200 hover:border-[var(--color-border-hover)] hover:shadow-md flex items-start gap-4 group"
>
  <Icon name={icon} />
  <div>
    <h3 class="text-xl font-bold group-hover:underline text-[var(--color-ink)]">{titlu}</h3>
    <p class="opacity-70 mt-1 text-sm text-[var(--color-ink)]">{rezumat}</p>
  </div>
</a>